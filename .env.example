# ======================
# Application Settings
# ======================
APP_NAME=ExcellentInsight
APP_ENV=development
DEBUG=true
PORT=5000

# CORS: comma-separated list of allowed frontend origins
# Example: CORS_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
CORS_ORIGINS=["http://localhost:3000"]

# ======================
# Database
# ======================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=excellent_insight
# Use Docker service names for container-to-container communication
DATABASE_URL=postgresql+asyncpg://postgres:change-me-in-production@localhost:5432/excellent_insight

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5

# ======================
# Redis
# ======================
# SECURITY: Generate strong password with: openssl rand -base64 32
REDIS_PASSWORD=change-me-in-production
# For local development without auth:
# REDIS_URL=redis://localhost:6379
# For production with auth (Docker):
# REDIS_URL=redis://:your-password@redis:6379
REDIS_URL=redis://:change-me-in-production@localhost:6379

# ======================
# Security
# ======================
# Generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=30

# ======================
# LLM (OpenRouter)
# ======================
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default models (can be changed)
LLM_MODEL=arcee-ai/trinity-large-preview:free
LLM_FALLBACK_MODEL=openai/gpt-oss-120b:free
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.1
LLM_CACHE_TTL_HOURS=24

# ======================
# File Upload
# ======================
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads
MAX_FILE_SIZE_MB=100
MAX_SHEETS_PER_FILE=20
MAX_ROWS_PER_SHEET=500000

# ======================
# Background Workers (ARQ)
# ======================
ARQ_MAX_JOBS=5
ARQ_JOB_TIMEOUT=1800  # 30 minutes (increased from 15min for complex pipelines)
ARQ_RESULT_TTL=3600

# ======================
# Optional: Logging
# ======================
LOG_LEVEL=INFO

# ======================
# Frontend (set in docker-compose or frontend/.env.local)
# ======================
# NEXT_PUBLIC_API_URL=https://yourdomain.com/api/v1
